{
  "name": "ai-script-generator",
  "version": "1.0.0",
  "description": "AI-powered call script generator for LyraForge voice receptionist",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "test": "jest --runInBand",
    "lint": "eslint . --ext .js --ignore-pattern public/js/lib",
    "lint:fix": "eslint . --ext .js --ignore-pattern public/js/lib --fix"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.3.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2"
  }
}
